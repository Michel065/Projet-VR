  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshPro
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\n\n\nCe projet a pour objectif de sensibiliser aux cons\xE9quences n\xE9gatives
    li\xE9es \xE0 la consommation d\u2019alcool et de substances psychoactives.\n\xC0
    travers une exp\xE9rience immersive, il met en \xE9vidence certains effets alt\xE9rant
    la perception, la prise de d\xE9cision et les r\xE9flexes, pouvant conduire \xE0
    des situations dangereuses.\n\nCette simulation vise notamment \xE0 illustrer
    les risques r\xE9els tels que la perte de contr\xF4le, la diminution de la vigilance
    ou encore les comportements \xE0 risque.\n\nEn cliquant sur \xAB Oui \xBB, vous
    serez expos\xE9 \xE0 une reproduction de certains de ces effets.\nCette exp\xE9rience
    peut \xEAtre perturbante pour certaines personnes.\n\nCe projet n\u2019a en aucun
    cas pour but de glorifier ou d\u2019encourager la consommation de stup\xE9fiants,
    mais bien de sensibiliser aux dangers qu\u2019ils repr\xE9sentent."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
